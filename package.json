{
  "name": "rss-angular-keycloak",
  "version": "0.0.1",
  "author": "Rodrigo S. Santos",
  "homepage": "https://github.com/rodrigossbr/rss-angular-keycloak#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rodrigossbr/rss-angular-keycloak.git"
  },
  "bugs": {
    "url": "https://github.com/rodrigossbr/rss-angular-keycloak/issues"
  },
  "description": "Ecossistema de autenticação moderna com Angular 21 e Keycloak 24. Implementa Authorization Code Flow com PKCE, Silent SSO e gerenciamento de estado reativo com @rssbr/state-store.",
  "keywords": [
    "angular-21",
    "keycloak-24",
    "keycloak-angular",
    "oidc",
    "oauth2",
    "pkce",
    "signals",
    "state-management",
    "reactive-programming",
    "standalone-components",
    "docker-compose",
    "security",
    "sso",
    "frontend-architecture"
  ],
  "scripts": {
    "ng": "ng",
    "prestart": "docker compose -f keycloak/docker-compose.yml down -v && docker compose -f keycloak/docker-compose.yml up -d",
    "start": "ng serve --open",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/material": "^21.2.2",
    "@angular/platform-browser": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@rssbr/state-store": "^0.0.2",
    "keycloak-angular": "^21.0.0",
    "keycloak-js": "^26.2.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
